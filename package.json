{
  "name": "@globio/cli",
  "version": "0.1.9",
  "description": "The official CLI for Globio — game backend as a service",
  "type": "module",
  "license": "MIT",
  "bin": {
    "globio": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "dev": "tsup src/index.ts --format esm --out-dir dist --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@globio/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "figlet": "^1.11.0",
    "firebase-admin": "^12.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
